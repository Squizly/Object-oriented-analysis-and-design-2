<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Кнопки -->
    <Style Selector="Button.ModernButton">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    
    <Style Selector="Button.ModernButton.Primary">
        <Setter Property="Background" Value="#007AFF"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.ModernButton.Success">
        <Setter Property="Background" Value="#34C759"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.ModernButton.Warning">
        <Setter Property="Background" Value="#FF9500"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.ModernButton.Danger">
        <Setter Property="Background" Value="#FF3B30"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <!-- Поля ввода -->
    <Style Selector="TextBox.ModernInput">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderBrush" Value="#D1D1D6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <!-- Карточки заметок -->
    <Style Selector="Border.NoteCard">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="BoxShadow" Value="0 1 2 #00000010"/>
    </Style>
    
    <!-- Списки -->
    <Style Selector="ListBox.NoteList">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>
    
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#E5E5EA"/>
    </Style>
    
    <!-- Список задач -->
    <Style Selector="Border.TaskList">
        <Setter Property="Background" Value="#F9F9FB"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow" Value="0 1 2 #00000008"/>
    </Style>
    
    <!-- Футер -->
    <Style Selector="Border.Footer">
        <Setter Property="Background" Value="#F9F9FB"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
    </Style>
    
    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="FontSize" Value="14"/>
    </Style>
</Styles>